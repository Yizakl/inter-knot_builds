# 1. 引入 Flutter 依赖加载脚本（解决 undefined method 报错的关键）
flutter_install_all_ios_pods_file = File.join(File.dirname(File.expand_path(__FILE__)), 'Flutter', 'podhelper.rb')
require flutter_install_all_ios_pods_file

# 2. 强制指定最低 iOS 版本为 13.0
platform :ios, '13.0'

# 3. 核心配置
target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # 运行 Flutter 插件安装
  flutter_install_all_ios_pods File.dirname(File.expand_path(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end
end
